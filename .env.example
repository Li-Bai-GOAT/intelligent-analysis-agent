# =============================================================================
# 数据分析智能体 - 环境配置示例
# 复制此文件为 .env 并填入实际值
# =============================================================================

# ==================== AI 模型配置 ====================
# 模型提供商选择: deepseek, minimax, openai, anthropic
MODEL_PROVIDER=deepseek
MODEL_TEMPERATURE=0.5
MAX_TOKENS=120000
TOOL_OUTPUT_MAX_LENGTH=8000

# DeepSeek 配置
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-reasoner

# MiniMax 配置 (Anthropic API 兼容)
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
MINIMAX_MODEL_NAME=MiniMax-M2.5

# OpenAI 配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o

# Anthropic 配置
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL_NAME=claude-sonnet-4-20250514

# ==================== 上下文压缩配置 ====================
COMPRESS_THRESHOLD_PERCENT=70
COMPRESS_KEEP_RECENT=10
# 压缩模型配置（可选，留空则使用主模型配置）
COMPRESS_MODEL_PROVIDER=
COMPRESS_MODEL_NAME=

# ==================== Embedding 服务 ====================
EMBEDDING_API_KEY=none
EMBEDDING_BASE_URL=http://localhost:9997/v1
EMBEDDING_MODEL=Qwen3-Embedding-4B

# ==================== 数据库配置 ====================
# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-password

# Redis
REDIS_URL=redis://:your-password@localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://:your-password@localhost:6379/1
CELERY_BACKEND_URL=redis://:your-password@localhost:6379/2
CELERY_RESULT_EXPIRES=3600
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# ==================== 应用服务配置 ====================
APP_HOST=0.0.0.0
APP_PORT=8090
ENVIRONMENT=development
DEBUG=release
CORS_ORIGINS=http://localhost:8090,http://127.0.0.1:8090,http://localhost:5173,http://127.0.0.1:5173

# ==================== 沙箱服务配置 ====================
SANDBOX_BASE_URL=http://localhost:10001
SANDBOX_BEARER_TOKEN=your-sandbox-token
# 默认只暴露 run_kuncode 给外层 Agent；如需调试再打开以下工具
ENABLE_AGENT_PYTHON_TOOL=false
ENABLE_AGENT_SHELL_TOOL=false

# ==================== Milvus 向量数据库 ====================
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=root:Milvus
MILVUS_DATABASE=rca_agent
MILVUS_DIM=768
MILVUS_COLLECTION=rca_knowledge_base
