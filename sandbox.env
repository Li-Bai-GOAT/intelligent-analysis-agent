# =============================================================================
# AgentScope Runtime Sandbox Server 配置文件
# 参考: https://runtime.agentscope.io/v1.0.4/zh/sandbox/advanced.html
# =============================================================================

# ==================== API 服务设置 ====================
HOST=0.0.0.0
PORT=10001
WORKERS=2
DEBUG=False
BEARER_TOKEN=mysecrettoken123

# ==================== 沙箱管理器设置 ====================
# 默认沙箱类型 (可选: base, browser, filesystem, gui 等)
# 使用自定义沙箱类型: data_analysis
DEFAULT_SANDBOX_TYPE=data_analysis

# 预热容器池大小 (缓存就绪容器以加快启动)
POOL_SIZE=2

# 服务器关闭时自动清理容器
AUTO_CLEANUP=True

# 容器名称前缀
CONTAINER_PREFIX_KEY=data-sandbox-

# 容器运行时: docker 或 k8s
CONTAINER_DEPLOYMENT=docker

# 挂载目录 (用于持久化 /workspace 文件,使用绝对路径，避免 os.getcwd() 在某些环境下失败)
DEFAULT_MOUNT_DIR=sessions_mount_dir

# 端口范围
PORT_RANGE=[49152,59152]

# ==================== 沙箱环境变量 ====================
# 这些变量会传递到沙箱容器内部
KUNCODE_MODEL=deepseek/deepseek-v4-flash
# Key 可只放在 .env 的 DEEPSEEK_API_KEY 中；启动时会自动传入沙箱容器。
DEEPSEEK_BASE_URL=https://api.deepseek.com
# ==================== Redis 设置 ====================
# 多 Worker 时需要 Redis 来共享沙箱状态
REDIS_ENABLED=True
REDIS_SERVER=localhost
REDIS_PORT=6380
REDIS_DB=5
REDIS_PASSWORD=password

# ==================== 文件系统设置 ====================
FILE_SYSTEM=local
# 存储目录 (使用绝对路径，避免 os.getcwd() 在某些环境下失败)
STORAGE_FOLDER=sessions_mount_dir
